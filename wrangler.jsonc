{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "apoorv-profile",
  "compatibility_date": "2026-07-11",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "apoorvdarshan.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
